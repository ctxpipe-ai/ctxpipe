{
  "name": "ctxpipe",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "bun": "^1.3.11"
  },
  "scripts": {
    "dev": "bash scripts/dev-apps.sh",
    "dev:docs": "pnpm --filter @ctxpipe/docs dev",
    "dev:infra": "docker compose --profile infra up -d",
    "start": "docker compose --profile deploy up -d",
    "dev:backend": "pnpm --filter @ctxpipe/backend dev",
    "db:migrate": "pnpm --filter @ctxpipe/backend db:migrate",
    "build": "turbo build",
    "lint": "biome lint apps packages",
    "format": "biome format apps packages adr",
    "mcp:inspect": "pnpm --filter @ctxpipe/backend run mcp:inspect",
    "trust": "pnpm exec portless trust",
    "changeset": "changeset",
    "ci:stamp-aws-cdk-image-tag": "node scripts/release/stamp-aws-cdk-image-tag.mjs",
    "ci:version": "changeset version",
    "ci:prerelease-version": "changeset version --snapshot",
    "ci:prerelease-publish": "changeset publish --no-git-tag",
    "release": "pnpm -r --filter \"./packages/*\" run --if-present build && pnpm -r --filter \"./packages/*\" run --if-present test && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@biomejs/biome": "^2.4.4",
    "concurrently": "^9.1.0",
    "portless": "^0.9.4",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@luma.gl/core": "9.2.6",
      "@luma.gl/engine": "9.2.6",
      "@luma.gl/webgl": "9.2.6",
      "@luma.gl/shadertools": "9.2.6",
      "@luma.gl/constants": "9.2.6"
    }
  }
}
