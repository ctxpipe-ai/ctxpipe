# Copy to `.env` next to docker-compose.yml (Compose loads it automatically).
#
# Multiple git worktrees: use the SAME `COMPOSE_PROJECT_NAME` in every checkout’s
# root `.env` (e.g. ctxpipe-dev) so `docker compose up` targets one shared Postgres /
# FalkorDB stack. Otherwise each worktree’s directory name becomes the project name
# and a second `docker compose up` tries to bind the same ports and fails.
#
# Use different CTXPIPE_* host ports when another stack or process already binds
# the defaults (e.g. multiple agents or worktrees on one machine).

# COMPOSE_PROJECT_NAME=ctxpipe-dev

# Postgres stays reachable on the host at this port (shared across worktrees;
# use a separate database name per worktree — see AGENTS.md and scripts/worktree-db.sh).
CTXPIPE_POSTGRES_HOST_PORT=5433

CTXPIPE_FALKOR_REDIS_HOST_PORT=6379
CTXPIPE_FALKOR_BOLT_HOST_PORT=7687
CTXPIPE_FALKOR_ADMIN_HOST_PORT=3003

CTXPIPE_OTEL_COLLECTOR_HOST_PORT=4318

CTXPIPE_BACKEND_HOST_PORT=3000
CTXPIPE_UI_HOST_PORT=3002
CTXPIPE_CODESEARCH_HOST_PORT=3001

# --- Deploy profile (`pnpm start` / `docker compose --profile deploy up`) ---
# Required for app containers (min 32 characters):
# AUTH_SECRET=
# Public URL of the API as seen by browsers (Better Auth, links):
# AUTH_BASE_URL=http://localhost:3000
# Baked into the UI image at build time (often same as AUTH_BASE_URL):
# CTXPIPE_PUBLIC_APP_URL=http://localhost:3000
# Optional comma-separated extra origins for Better Auth:
# AUTH_ALLOWED_ORIGINS=
# Optional GitHub token for codesearch repo cloning:
# GITHUB_TOKEN=
#
# GitHub App (repository connectors) — optional after DB rows have encrypted credentials:
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=   # multiline PEM
# GITHUB_WEBHOOK_SECRET=  # also used for legacy POST /api/v1/webhook/github
# GITHUB_APP_SLUG=ctxpipe-agent  # install URL slug for bootstrap API
# CONNECTION_SECRETS_ENCRYPTION_KEY=  # 64 hex chars; default derives from AUTH_SECRET

# Amplitude (optional) — use the same values on backend and UI services (runtime env; no UI image rebuild).
# AMPLITUDE_API_KEY=
# AMPLITUDE_REGION=us

# --- Confluence / Forge (optional, hosted or local) ---
# Fallback marketplace install URL when a forge `connections.config` has no `confluenceForgeInstallUrl` (capabilities / Install step).
# Mirror the same optional value from the backend on the UI service (SSR/root loader); the OSS UI bundle also commits a managed-app default URL.
# CONFLUENCE_FORGE_INSTALL_URL=
