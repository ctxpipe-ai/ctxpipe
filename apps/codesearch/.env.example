# Database
DATABASE_URL=postgresql://ctxpipe:ctxpipe@localhost:5433/ctxpipe
GRAPH_DB_URI=redis://localhost:6379
# Required, must be >= 32 characters.
AUTH_SECRET=
AUTH_BASE_URL=http://localhost:3000

# Zoekt RPC (inside Docker container from start.sh; default 6070)
ZOEKT_WEBSERVER_URL=http://127.0.0.1:6070

# Optional: index + clone dirs (defaults from `pnpm dev` via dev-apps.sh → apps/codesearch/.data/)
# ZOEKT_INDEX_DIR=/absolute/path/to/zoekt-index
# REPO_CACHE_DIR=/absolute/path/to/repo-cache
