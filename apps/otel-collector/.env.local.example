# Local dev: copy to .env.local and fill in secrets.
# cp apps/otel-collector/.env.local.example apps/otel-collector/.env.local
#
# Langfuse runs on the host; the collector container reaches it via host.docker.internal.

# Better Stack (logs + traces)
BETTER_STACK_TOKEN=

# LangFuse — self-hosted on host (UI at http://localhost:3000)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://host.docker.internal:3000
LANGFUSE_OTLP_ENDPOINT=http://host.docker.internal:3000/api/public/otel

# Derived — set after creating LANGFUSE_PUBLIC_KEY and LANGFUSE_SECRET_KEY in Langfuse project settings:
# LANGFUSE_AUTH_STRING = base64("publicKey:secretKey")
#   Generate: echo -n 'pk-lf-xxx:sk-lf-xxx' | base64
LANGFUSE_AUTH_STRING=
