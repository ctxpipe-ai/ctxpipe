# OpenTelemetry Collector — Better Stack + LangFuse
# Copy to .env and fill in values. Used when running via docker compose.
#
# For local self-hosted Langfuse, prefer copying .env.local.example → .env.local instead.

# Better Stack (logs + traces)
BETTER_STACK_TOKEN=

# LangFuse (traces) — Langfuse Cloud (deploy / shared team default)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Local self-hosted Langfuse on the host (collector runs in Docker — use host.docker.internal, not localhost):
# LANGFUSE_BASE_URL=http://host.docker.internal:3000
# LANGFUSE_OTLP_ENDPOINT=http://host.docker.internal:3000/api/public/otel
# Create API keys in the Langfuse UI at http://localhost:3000 (project settings).

# Derived — set after creating LANGFUSE_PUBLIC_KEY and LANGFUSE_SECRET_KEY:
# LANGFUSE_AUTH_STRING = base64("publicKey:secretKey")
#   Generate: echo -n 'pk-lf-xxx:sk-lf-xxx' | base64
# LANGFUSE_OTLP_ENDPOINT = LANGFUSE_BASE_URL + "/api/public/otel"
LANGFUSE_AUTH_STRING=
LANGFUSE_OTLP_ENDPOINT=
