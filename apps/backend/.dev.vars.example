# Example .dev.vars for backend Wrangler dev
# Copy this file to `.dev.vars` in the same directory and adjust as needed.

# PostgreSQL connection string used by Drizzle and the backend.
DATABASE_URL=postgresql://ctxpipe:ctxpipe@localhost:5433/ctxpipe

# Neo4j Bolt URI for future graph features.
NEO4J_URI=bolt://localhost:7687

