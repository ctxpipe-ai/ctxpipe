# Database
DATABASE_URL=postgresql://ctxpipe:ctxpipe@localhost:5433/ctxpipe
# Host dev via `pnpm dev` (portless): dev-apps.sh sets UI_PROXY_URL from `portless get ui.ctxpipe` (use that hostname + proxy port, e.g. https://ui.ctxpipe.localhost:1355 — not 127.0.0.1 or a guessed localhost port).
# For UI-only dev without portless, point at the Vite dev server (e.g. http://localhost:3002).
UI_PROXY_URL=http://localhost:3002

# Graph DB (OpenCypher: FalkorDB, Neo4j, Memgraph, Neptune)
# Defaults to redis://falkordb:6379 when unset (Docker / Railway). For local host dev use redis://localhost:6379.
GRAPH_DB_URI=redis://localhost:6379
# GRAPH_DB_USER=default
# GRAPH_DB_PASSWORD=
# GRAPH_DB_PROVIDER=falkordb
# Per-org URIs for instance-per-tenant multi-org (e.g. GRAPH_DB_URI_acme=bolt://...)
# Required, must be >= 32 characters.
AUTH_SECRET=
AUTH_BASE_URL=http://localhost:3000
# Optional comma-separated list of additional browser origins for Better Auth.
# With portless (`pnpm dev`), dev-apps.sh sets this from `portless get` URLs.
AUTH_ALLOWED_ORIGINS=
# Optional override; `pnpm dev` sets CODESEARCH_URL from the codesearch Docker container (random localhost port).
# CODESEARCH_URL=http://127.0.0.1:3001

# Email (SMTP) — optional. Without this, reset emails are logged to console.
# Works with any SMTP provider: Resend (smtp.resend.com:465), AWS SES, Postmark, etc.
SMTP_CONNECTION_URL=
EMAIL_FROM_ADDRESS=

# LLM and embeddings (OpenRouter, OpenAI, Vertex, Bedrock, Ollama, etc.)
MODEL_PROVIDER_API_KEY=
MODEL_PROVIDER_URL=
# Optional overrides: MODEL_FAST_NAME, MODEL_MEDIUM_NAME, MODEL_HIGH_NAME
# MODEL_EMBEDDING_PROVIDER_URL= (default: {MODEL_PROVIDER_URL}/embeddings)
# MODEL_EMBEDDING_PROVIDER_API_KEY= (default: MODEL_PROVIDER_API_KEY)
# MODEL_EMBEDDING_NAME=openai/text-embedding-3-large
# See docs/self-hosting/models.md for details.

# OpenTelemetry — send traces/logs to collector. When using docker compose, backend
# connects to otel-collector at http://otel-collector:4318. Leave unset to disable.
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://otel-collector:4318/v1/logs
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://otel-collector:4318/v1/metrics
OTEL_SERVICE_NAME=ctxpipe-backend
# deployment.environment.name for filtering traces (e.g. development, staging, production)
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment.name=development

# GitHub OAuth (for sign in with GitHub)
# Create an OAuth App at https://github.com/settings/developers
# For local development grab the client from link below
# And generate a new client secret from there too
# https://github.com/organizations/ctxpipe-ai/settings/apps/ctxpipe-agent-localhost
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ctxpipe github app (for repository integrations)
GITHUB_APP_ID=3037875
# Full PEM content (paste entire -----BEGIN ... ----- block)
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
SMEE_URL="https://smee.io/naliyA6yt5p9UmLf"