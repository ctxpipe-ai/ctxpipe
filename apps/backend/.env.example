# Database
DATABASE_URL=postgresql://ctxpipe:ctxpipe@localhost:5433/ctxpipe
UI_PROXY_URL=http://localhost:3002
# Required, must be >= 32 characters.
AUTH_SECRET=
AUTH_BASE_URL=http://localhost:3000
# Optional comma-separated list of additional browser origins for Better Auth.
# Example when running browser over TLS locally:
# AUTH_ALLOWED_ORIGINS=https://localhost:3000,http://localhost:3000
AUTH_ALLOWED_ORIGINS=

# Email (SMTP) — optional. Without this, reset emails are logged to console.
# Works with any SMTP provider: Resend (smtp.resend.com:465), AWS SES, Postmark, etc.
SMTP_CONNECTION_URL=
EMAIL_FROM_ADDRESS=

# LLM (OpenRouter)
MODEL_PROVIDER_API_KEY=
LANGSMITH_API_KEY=

# ctxpipe github app
GITHUB_APP_ID=3006674
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
