{
  "name": "@ctxpipe/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,worker \"ENABLE_LANGSMITH=true bun run --hot src/server.ts\" \"pnpm run openworkflow:worker\"",
    "build": "tsc",
    "start": "bun run dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "auth:migrate": "pnpm dlx auth@latest migrate --config ./src/auth/cli.ts --yes",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "mcp:inspect": "pnpm dlx @modelcontextprotocol/inspector --config ../../.cursor/mcp.json --server ctxpipe",
    "openworkflow:worker": "bunx @openworkflow/cli worker start",
    "openworkflow:dashboard": "pnpm dlx @openworkflow/cli dashboard",
    "openworkflow:doctor": "pnpm dlx @openworkflow/cli doctor"
  },
  "dependencies": {
    "@ai-sdk/langchain": "^2.0.111",
    "@better-auth/oauth-provider": "^1.4.18",
    "@better-auth/passkey": "^1.4.18",
    "@hono/mcp": "^0.2.3",
    "@hono/zod-openapi": "^1.2.2",
    "@langchain/core": "^1.1.27",
    "@langchain/langgraph": "^1.1.5",
    "@langchain/langgraph-api": "^1.1.13",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/openai": "^1.2.9",
    "@react-email/components": "^0.0.36",
    "@react-email/render": "^1.0.5",
    "@scalar/hono-api-reference": "^0.9.44",
    "@scure/base": "^2.0.0",
    "@sindresorhus/slugify": "^3.0.0",
    "@toon-format/toon": "^2.1.0",
    "ai": "^6.0.105",
    "better-auth": "^1.4.18",
    "drizzle-orm": "beta",
    "hono": "^4.12.1",
    "jose": "^6.1.3",
    "langchain": "^1.2.25",
    "nodemailer": "^6.10.1",
    "openworkflow": "^0.8.0",
    "pg": "^8.18.0",
    "postgres": "^3.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "@modelcontextprotocol/sdk": "^1.26.0"
  },
  "devDependencies": {
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@modelcontextprotocol/conformance": "^0.1.15",
    "@openworkflow/cli": "^0.4.2",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.1.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "beta",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
