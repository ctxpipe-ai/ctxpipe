{
  "name": "@ctxpipe/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,worker \"ENABLE_LANGSMITH=true NODE_TLS_REJECT_UNAUTHORIZED=0 portless app.ctxpipe bun run --hot src/server.ts\" \"pnpm run openworkflow:worker\"",
    "build": "tsc",
    "start": "bun run dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "auth:migrate": "pnpm dlx auth@latest migrate --config ./src/auth/cli.ts --yes",
    "db:migrate": "bash -c 'source ../../scripts/worktree-db.sh && drizzle-kit migrate'",
    "migrate": "pnpm run db:migrate",
    "db:studio": "drizzle-kit studio",
    "mcp:inspect": "pnpm dlx @modelcontextprotocol/inspector --config ../../.cursor/mcp.json --server ctxpipe",
    "openworkflow:worker": "NODE_TLS_REJECT_UNAUTHORIZED=0 bunx @openworkflow/cli worker start",
    "openworkflow:dashboard": "pnpm dlx @openworkflow/cli dashboard --port 8000",
    "openworkflow:doctor": "pnpm dlx @openworkflow/cli doctor",
    "rerun-skill-derivation": "bun run src/scripts/rerunSkillDerivation.ts",
    "verify-instruction-ingestion": "bun run src/scripts/verifyInstructionIngestion.ts",
    "forward-github-webhook": "NODE_EXTRA_CA_CERTS=$HOME/.portless/ca.pem smee -u ${SMEE_URL:-https://smee.io/naliyA6yt5p9UmLf} -t https://app.ctxpipe.localhost:1355/api/v1/webhook/github"
  },
  "dependencies": {
    "@ai-sdk/langchain": "^2.0.111",
    "@better-auth/infra": "^0.1.13",
    "@better-auth/oauth-provider": "^1.5.6",
    "@better-auth/passkey": "^1.5.6",
    "@hono/mcp": "^0.2.3",
    "@hono/zod-openapi": "^1.2.2",
    "@langchain/core": "^1.1.27",
    "@langchain/langgraph": "^1.1.5",
    "@langchain/langgraph-api": "^1.1.13",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/openai": "^1.2.9",
    "@langfuse/langchain": "^5.0.0",
    "@langfuse/otel": "^5.0.0",
    "@langfuse/tracing": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@octokit/webhooks": "^14.2.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@openworkflow/cli": "^0.4.2",
    "@react-email/components": "^0.0.36",
    "@react-email/render": "^1.0.5",
    "@scalar/hono-api-reference": "^0.9.44",
    "@scure/base": "^2.0.0",
    "@sindresorhus/slugify": "^3.0.0",
    "@toon-format/toon": "^2.1.0",
    "ai": "^6.0.105",
    "better-auth": "^1.5.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "beta",
    "evlog": "^2.5.0",
    "falkordb": "^6.6.2",
    "hono": "^4.12.1",
    "jose": "^6.1.3",
    "langchain": "^1.2.25",
    "neo4j-driver": "^6.0.1",
    "nodemailer": "^6.10.1",
    "octokit": "^4.0.2",
    "openworkflow": "^0.8.0",
    "pg": "^8.18.0",
    "postgres": "^3.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@modelcontextprotocol/conformance": "^0.1.15",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "beta",
    "smee-client": "^5.0.0",
    "tsx": "4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
