{
  "name": "@ctxpipe/aws-cdk",
  "version": "2.0.0",
  "description": "AWS CDK construct library for self-hosting ctxpipe",
  "private": false,
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "README.md"
  ],
  "scripts": {
    "stamp-image-tag": "node ./scripts/stamp-image-tag.mjs",
    "prebuild": "pnpm run stamp-image-tag",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf lib"
  },
  "keywords": [
    "cdk",
    "aws",
    "ecs",
    "ctxpipe"
  ],
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ctxpipe-ai/ctxpipe.git",
    "directory": "packages/aws-cdk"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.252.0",
    "constructs": "^10.4.2"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
