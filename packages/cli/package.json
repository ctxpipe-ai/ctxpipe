{
  "name": "ctxpipe",
  "version": "0.1.1",
  "description": "Universal ctx| CLI for initializing repositories and agent integrations.",
  "type": "module",
  "bin": {
    "ctxpipe": "./bin/ctxpipe.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm run build",
    "prepack": "pnpm run build",
    "test": "vitest run --exclude 'test/memory/integration-*.test.ts'",
    "test:memory:integration": "vitest run test/memory/integration-agentmemory.test.ts --testTimeout 120000",
    "test:all": "pnpm run test && pnpm run test:memory:integration"
  },
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctxpipe-ai/ctxpipe.git",
    "directory": "packages/cli"
  },
  "homepage": "https://ctxpipe.ai",
  "bugs": {
    "url": "https://github.com/ctxpipe-ai/ctxpipe/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@napi-rs/keyring": "^1.3.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "25.3.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
