{
  "name": "ctxpipe",
  "version": "0.1.0-alpha.1",
  "description": "Universal ctx| CLI for initializing repositories and agent integrations.",
  "type": "module",
  "bin": {
    "ctxpipe": "./bin/ctxpipe.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm run build",
    "test": "vitest run"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctxpipe-ai/ctxpipe.git",
    "directory": "packages/cli"
  },
  "homepage": "https://ctxpipe.ai",
  "bugs": {
    "url": "https://github.com/ctxpipe-ai/ctxpipe/issues"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "25.3.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
