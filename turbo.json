{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "AUTH_BASE_URL",
    "UI_PROXY_URL",
    "AUTH_ALLOWED_ORIGINS",
    "VITE_PUBLIC_API_URL",
    "CODESEARCH_URL",
    "PORTLESS_PORT",
    "ZOEKT_WEBSERVER_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"],
      "cache": true
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "format": {
      "outputs": [],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": [],
      "cache": true
    },
    "migrate": {
      "cache": false,
      "outputs": []
    }
  }
}
