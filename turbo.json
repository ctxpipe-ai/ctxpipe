{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "AUTH_BASE_URL",
    "UI_PROXY_URL",
    "AUTH_ALLOWED_ORIGINS",
    "VITE_PUBLIC_API_URL",
    "CODESEARCH_URL",
    "PORTLESS_PORT",
    "ZOEKT_WEBSERVER_URL",
    "SMTP_CONNECTION_URL",
    "EMAIL_FROM_ADDRESS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "lib/**"],
      "cache": true
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "format": {
      "outputs": [],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": [],
      "cache": true
    },
    "migrate": {
      "cache": false,
      "outputs": []
    },
    "cdk:exec": {
      "dependsOn": ["^build"],
      "passThroughEnv": [
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_REGION",
        "AWS_DEFAULT_REGION"
      ],
      "cache": false,
      "outputs": []
    }
  }
}
